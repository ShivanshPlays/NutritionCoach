    {
      "name": "02 - Chat (POST /api/chat)",
      "description": "Free-text chat with the Gemini nutrition coach.\n\nMERN analogy: POST /api/chat route in an Express or Next.js App Router project.\n\nRequest:  { \"message\": string }   — @NotBlank validated\nResponse: { \"reply\": string }     — raw Gemini text\n\nBook ref: Chapter 2 — first end-to-end LLM round-trip.",
      "item": [
        {
          "name": "POST /api/chat — happy path",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"message\": \"What are the best foods for muscle recovery after a workout?\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/chat",
              "host": ["{{base_url}}"],
              "path": ["api", "chat"]
            },
            "description": "Sends a nutrition question to Gemini via Spring AI ChatClient.\n\nThe system prompt is hardcoded in ChatController (Phase 0).\nIn later phases this will be loaded from a versioned .st template."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains reply field', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('reply');",
                  "    pm.expect(json.reply).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "// Save reply for potential chaining in later requests",
                  "const json = pm.response.json();",
                  "if (json.reply) {",
                  "    pm.environment.set('last_chat_reply', json.reply);",
                  "}"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "200 OK — example reply",
              "originalRequest": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"message\": \"What are the best foods for muscle recovery after a workout?\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/chat",
                  "host": ["{{base_url}}"],
                  "path": ["api", "chat"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n    \"reply\": \"Great question! After a workout, focus on protein for muscle repair (chicken, eggs, Greek yogurt) and carbohydrates to replenish glycogen (sweet potato, rice, fruit). Aim to eat within 30–60 minutes post-workout.\"\n}"
            }
          ]
        },
        {
          "name": "POST /api/chat — blank message (400 validation)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"message\": \"\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/chat",
              "host": ["{{base_url}}"],
              "path": ["api", "chat"]
            },
            "description": "Sends a blank message — should trigger @NotBlank Bean Validation.\n\nMERN analogy: like sending an empty string to a Zod z.string().min(1) field.\n\nExpected: 400 Bad Request."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 400 (validation error)', () => {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
