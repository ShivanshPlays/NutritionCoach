    {
      "name": "03 - Research Summary (POST /api/research-summary)",
      "description": "Structured output endpoint — returns a ResearchBrief JSON object instead of free text.\n\nPhase 1 implementation: ChatClient called directly.\nPhase 2 implementation (current): Backed by Embabel @Agent (ResearchAgent).\n  AgentPlatform auto-selects ResearchAgent via goal type (ResearchBrief),\n  then GOAP planner runs gatherFacts(@Action) → ResearchBrief (@AchievesGoal).\n\nMERN analogy: mastra.getAgent('researchAgent').generate({ topic }).\n\nRequest:  { \"topic\": string }   — @NotBlank validated\nResponse: ResearchBrief { topic, keyFindings[], risks[], nextQuestions[] }\n\nBook ref: Chapter 4 — Agents 101 (Embabel focused invocation).\nBook ref: Chapter 5 — Structured Output (createObject instead of entity).",
      "item": [
        {
          "name": "POST /api/research-summary — happy path",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"topic\": \"vitamin D and immune function\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/research-summary",
              "host": ["{{base_url}}"],
              "path": ["api", "research-summary"]
            },
            "description": "Requests a structured ResearchBrief for a given nutrition topic.\n\nThe model is guided by the versioned system prompt in prompts/research-system.st\nand forced to return JSON matching the ResearchBrief schema."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has all ResearchBrief fields', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('topic');",
                  "    pm.expect(json).to.have.property('keyFindings');",
                  "    pm.expect(json).to.have.property('risks');",
                  "    pm.expect(json).to.have.property('nextQuestions');",
                  "});",
                  "",
                  "pm.test('keyFindings is a non-empty array', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.keyFindings).to.be.an('array').and.not.empty;",
                  "});",
                  "",
                  "pm.test('risks is an array', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.risks).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('nextQuestions is an array', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.nextQuestions).to.be.an('array');",
                  "});",
                  "",
                  "// Save researched topic for potential chaining",
                  "const json = pm.response.json();",
                  "if (json.topic) {",
                  "    pm.environment.set('last_research_topic', json.topic);",
                  "}"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "200 OK — example ResearchBrief",
              "originalRequest": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"topic\": \"vitamin D and immune function\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/research-summary",
                  "host": ["{{base_url}}"],
                  "path": ["api", "research-summary"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n    \"topic\": \"vitamin D and immune function\",\n    \"keyFindings\": [\n        \"Vitamin D receptors are present on nearly all immune cells\",\n        \"Deficiency is associated with increased susceptibility to respiratory infections\",\n        \"Supplementation may reduce severity of autoimmune conditions\"\n    ],\n    \"risks\": [\n        \"Toxicity possible with excessive supplementation (>4000 IU/day long-term)\",\n        \"Interactions with certain medications (thiazide diuretics, steroids)\"\n    ],\n    \"nextQuestions\": [\n        \"What blood level of 25-OH vitamin D is considered optimal for immune health?\",\n        \"Does sunlight exposure provide sufficient vitamin D at northern latitudes?\"\n    ]\n}"
            }
          ]
        },
