			"name": "02 - Chat (POST /api/chat)",
			"item": [
				{
					"name": "POST /api/chat — happy path",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', () => {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response contains reply field', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('reply');",
									"    pm.expect(json.reply).to.be.a('string').and.not.empty;",
									"});",
									"",
									"// Save reply for potential chaining in later requests",
									"const json = pm.response.json();",
									"if (json.reply) {",
									"    pm.environment.set('last_chat_reply', json.reply);",
									"}"
								],
